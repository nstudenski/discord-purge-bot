# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Optional overrides (defaults shown)
# How often to scan channels for newly-eligible-for-deletion messages
POLL_INTERVAL_HOURS=24
# How often the deletion worker runs
DELETE_INTERVAL_MINUTES=5
# Max messages deleted per deletion-worker tick
DELETE_BATCH_SIZE=5
# Delay between individual delete calls within a tick (ms)
DELETE_INTER_MESSAGE_DELAY_MS=1000
# Path to the sqlite database file (defaults to ./data.sqlite3)
DB_PATH=
